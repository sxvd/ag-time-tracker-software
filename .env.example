# Local non-Docker development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ag_time_tracker?schema=public"
NUXT_SESSION_PASSWORD="local-dev-session-secret-32-characters"
NUXT_AI_INSIGHTS_API_KEY=""

# Docker development and production PostgreSQL defaults
# deploy.sh creates server-only production secrets in .env.production.
POSTGRES_DB="ag_time_tracker"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"

# Production deployment below https://tools.airgradient.net/tracker
PORT="5500"
NITRO_HOST="0.0.0.0"
NUXT_APP_BASE_URL="/tracker/"
